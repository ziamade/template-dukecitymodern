---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyHeader from '../components/StickyHeader.astro';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import ProjectGallery from '../components/ProjectGallery.astro';
import TrustBadges from '../components/TrustBadges.astro';
import TrustStats from '../components/TrustStats.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import MenuSection from '../components/MenuSection.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import QuoteForm from '../components/QuoteForm.astro';
import OrderVisit from '../components/OrderVisit.astro';
import AboutMap from '../components/AboutMap.astro';
import HoursDisplay from '../components/HoursDisplay.astro';
import Footer from '../components/Footer.astro';
import StickyActionBar from '../components/StickyActionBar.astro';
import Divider from '../components/Divider.astro';
import ScrollMoment from '../components/ScrollMoment.astro';

import client from '../data/client.json';
import contact from '../data/contact.json';
import location from '../data/location.json';
import testimonials from '../data/testimonials.json';
import theme from '../data/theme.json';

interface SectionEntry {
  id: string;
  variant?: string | number;
}

const isRestaurant = (client.industry || '').toLowerCase().includes('restaurant');
const hasReviews = testimonials?.items?.length > 0;

// Resolve trust component from theme variant
const trustVariant = (theme as any).sections?.find((s: any) => s.id === 'trust')?.variant;
const TrustComponent = trustVariant === 'stats' ? TrustStats : TrustBadges;

// Section component map
const sectionMap: Record<string, any> = {
  hero: Hero,
  trust: TrustComponent,
  services: ServiceCards,
  projects: ProjectGallery,
  process: ProcessSteps,
  gallery: PhotoGallery,
  menu: MenuSection,
  reviews: Reviews,
  faq: FAQ,
  contact: isRestaurant ? OrderVisit : QuoteForm,
  about: AboutMap,
  hours: HoursDisplay,
};

// Use theme.json sectionOrder or fall back to defaults
const defaultOrder = isRestaurant
  ? ['hero', 'menu', 'gallery', 'reviews', 'hours', 'about', 'contact']
  : ['hero', 'trust', 'services', 'projects', 'process', 'reviews', 'faq', 'contact', 'about'];

function resolveSections(themeData: any): SectionEntry[] {
  if (themeData.sections?.length > 0) return themeData.sections;
  const order = themeData.sectionOrder?.length > 0 ? themeData.sectionOrder : defaultOrder;
  return order.map((id: string) => {
    if (id === 'hero' && themeData.heroVariant) return { id, variant: themeData.heroVariant };
    return { id };
  });
}

const sections = resolveSections(theme);

// Build nav links from section order
const sectionLabels: Record<string, string> = {
  hero: '',       // not in nav
  trust: '',      // not in nav
  services: 'Services',
  projects: 'Our Work',
  process: '',    // not in nav
  gallery: 'Photos',
  menu: 'Menu',
  reviews: 'Reviews',
  faq: 'FAQ',
  contact: isRestaurant ? 'Order' : 'Contact',
  about: 'About',
  hours: 'Hours',
};

const navLinks = sections
  .filter(s => sectionLabels[s.id] && s.id !== 'hero')
  .filter(s => s.id !== 'reviews' || hasReviews)
  .map(s => ({ href: `#${s.id}`, text: sectionLabels[s.id] }));

const ctaText = isRestaurant ? 'Order Now' : 'Get Quote';
const ctaHref = isRestaurant ? '#contact' : '#contact';
const heroCta = isRestaurant
  ? { text: 'View Our Menu', href: '#menu' }
  : { text: 'Get Your Free Quote', href: '#contact' };
// Load SVG icons for action bar
const actionIcons = import.meta.glob('/src/assets/svgs/icons/*.svg', { query: '?raw', import: 'default', eager: true });
function actionIcon(name: string): string {
  return (actionIcons[`/src/assets/svgs/icons/${name}.svg`] as string) || '';
}

// Visual depth: dark section and dividers
const layout = (theme as any).layout || {};
const depth = layout.depth || '';
const darkSection = layout.darkSection || '';
const useEditorialDividers = depth === 'editorial';

const actionBarLinks = [
  { href: `tel:${contact.phoneForTel || ''}`, icon: actionIcon('phone'), text: 'Call' },
  { href: location.mapLink || '#', icon: actionIcon('navigation'), text: 'Directions' },
  { href: '#contact', icon: isRestaurant ? actionIcon('utensils') : actionIcon('mail'), text: isRestaurant ? 'Order' : 'Quote' },
];
---
<BaseLayout>
  <StickyHeader navLinks={navLinks} ctaText={ctaText} ctaHref={ctaHref} />

  {sections.map((entry, i) => {
    const Component = sectionMap[entry.id];
    if (!Component) return null;
    if (entry.id === 'reviews' && !hasReviews) return null;
    const isDark = darkSection && entry.id === darkSection;
    const nextEntry = sections[i + 1];
    const nextIsDark = nextEntry && darkSection && nextEntry.id === darkSection;

    // Editorial dividers: before dark sections and after hero
    const showDividerBefore = useEditorialDividers && isDark;
    const showDividerAfterHero = useEditorialDividers && entry.id === 'hero' && nextEntry;

    return (
      <>
        {showDividerAfterHero && <Divider to="var(--surface)" variant="gentle" />}
        {showDividerBefore && <Divider to="var(--text)" variant="wave" />}
        {isDark ? (
          <div data-section-mood="dark">
            {entry.id === 'hero'
              ? <Component heroCta={heroCta} variant={entry.variant} />
              : <Component variant={entry.variant} />}
          </div>
        ) : (
          entry.id === 'hero'
            ? <Component heroCta={heroCta} variant={entry.variant} />
            : <Component variant={entry.variant} />
        )}
        {isDark && useEditorialDividers && <Divider to="var(--background)" variant="curve" />}
        {entry.id === 'reviews' && <ScrollMoment />}
      </>
    );
  })}

  <Footer />
  <StickyActionBar links={actionBarLinks} />
</BaseLayout>
