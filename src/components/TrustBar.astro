---
// src/components/TrustBar.astro
// v4 NEW component (replaces TrustBadges.astro).
// PW Tint trust bar pattern: horizontal flex, large number/value + label,
// vertical dividers, data-driven from trustbar.json, .reveal-up with stagger.
let trustbar: any = { items: [] };
try { trustbar = (await import('../data/trustbar.json')).default; } catch {}

const items = trustbar?.items || [];
const hasItems = items.length > 0;
---
{hasItems && (
  <section class="trustbar-section" id="trust">
    <div class="container">
      <div class="trustbar stagger-parent">
        {items.map((item: any, i: number) => (
          <>
            {i > 0 && <span class="trustbar-divider" aria-hidden="true" />}
            <div class="trustbar-item reveal-up">
              {item.number && (
                <span class="trustbar-value">{item.number}</span>
              )}
              {item.label && (
                <span class="trustbar-label">{item.label}</span>
              )}
            </div>
          </>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ── Trust Bar Section ─────────────────────────────────────────── */

  .trustbar-section {
    padding: var(--gap-lg, 2rem) 0;
    border-top: 1px solid var(--borderSubtle, var(--border));
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 15%, var(--border));
    border-top: 1px solid color-mix(in srgb, var(--accent) 15%, var(--border));
    background: color-mix(in oklch, var(--surface) 100%, white 4%);
  }

  /* ── Trust bar container ────────────────────────────────────────── */

  .trustbar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-xl, 3rem);
    flex-wrap: wrap;
  }

  /* ── Vertical divider ──────────────────────────────────────────── */

  .trustbar-divider {
    width: 1px;
    height: 48px;
    background: var(--borderSubtle, var(--border));
    flex-shrink: 0;
  }

  /* ── Individual item ───────────────────────────────────────────── */

  .trustbar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--gap-xs, 0.25rem);
    min-width: 0;
  }

  /* ── Large number/value ──────────────────────────────────────────── */

  .trustbar-value {
    font-family: var(--font-heading);
    font-size: var(--title-size, clamp(1.5rem, 1.25rem + 1.25vw, 2.25rem));
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--accent);
    letter-spacing: var(--tracking-tight, -0.02em);
  }

  /* ── Label below the number ──────────────────────────────────────── */

  .trustbar-label {
    font-size: var(--small-size, 0.875rem);
    font-weight: 500;
    color: var(--textMuted, var(--text));
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide, 0.08em);
    line-height: 1.3;
    white-space: nowrap;
  }

  /* ── Mobile: wraps, hides dividers at small sizes ────────────────── */

  @media (max-width: 639px) {
    .trustbar {
      gap: var(--gap-lg, 2rem) var(--gap-xl, 3rem);
    }

    .trustbar-divider {
      display: none;
    }

    .trustbar-item {
      flex: 0 0 calc(50% - var(--gap-xl, 3rem) / 2);
    }

    .trustbar-value {
      font-size: var(--subhead-size, 1.5rem);
    }

    .trustbar-label {
      font-size: var(--caption-size, 0.75rem);
      white-space: normal;
    }
  }

  /* ── Tablet: slightly smaller gaps ───────────────────────────────── */

  @media (min-width: 640px) and (max-width: 1023px) {
    .trustbar {
      gap: var(--gap-lg, 2rem);
    }

    .trustbar-divider {
      height: 40px;
    }
  }
</style>
