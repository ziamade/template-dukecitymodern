---
// src/components/ThemeToggle.astro
// Sun/moon toggle for light/dark mode. Inserted in StickyHeader.
---
<button class="theme-toggle" id="theme-toggle" aria-label="Toggle color mode" type="button">
  <span class="theme-toggle-icon theme-toggle-sun">&#9788;</span>
  <span class="theme-toggle-icon theme-toggle-moon">&#9790;</span>
</button>
