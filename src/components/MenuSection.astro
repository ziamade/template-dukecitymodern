---
import menu from '../data/menu.json';
import client from '../data/client.json';

const categories = menu?.categories || [];
const hasMenu = categories.length > 0 && categories.some((c: any) => c.items?.length > 0);
const orderUrl = (client as Record<string, any>)?.orderUrl || '';
---
{hasMenu && (
  <section class="menu-section section" id="menu">
    <div class="container">
      <h2 class="section-heading">Menu</h2>

      <nav class="menu-nav" aria-label="Menu categories">
        {categories.map((cat: any, i: number) => (
          <a href={`#menu-cat-${i}`} class="menu-pill" data-cat-index={i}>
            {cat.name}
          </a>
        ))}
      </nav>

      {categories.map((cat: any, i: number) => (
        <div class="menu-category" id={`menu-cat-${i}`}>
          <h3 class="menu-category-name">{cat.name}</h3>
          <div class="menu-items">
            {cat.items.map((item: any) => (
              <div class={`menu-item ${item.featured ? 'menu-item--featured' : ''}`}>
                {item.featured && item.photo && (
                  <img
                    src={item.photo}
                    alt={item.name}
                    class="menu-item-photo"
                    loading="lazy"
                    width="280"
                    height="200"
                  />
                )}
                <div class="menu-item-content">
                  <div class="menu-item-header">
                    <span class="menu-item-name">{item.name}</span>
                    {item.price && item.price !== 'Ask' && (
                      <span class="menu-item-price">{item.price}</span>
                    )}
                    {item.price === 'Ask' && (
                      <span class="menu-item-price menu-item-price--ask">Ask</span>
                    )}
                  </div>
                  {item.description && (
                    <p class="menu-item-desc">{item.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      {orderUrl && (
        <div class="menu-order-cta">
          <a href={orderUrl} class="btn-primary" target="_blank" rel="noopener">
            Order Online
          </a>
          <p class="menu-order-note">Full menu and online ordering available</p>
        </div>
      )}
    </div>
  </section>
)}
