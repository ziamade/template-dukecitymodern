---
// src/components/PhotoGallery.astro
import gallery from '../data/gallery.json';
---
{(gallery?.images?.length > 0 || gallery?.items?.length > 0) && (
  <section class="gallery-section section" id="gallery">
    <div class="container">
      <h2 class="section-heading">Our Work</h2>
    </div>
    <div class="gallery-scroll">
      {(gallery.images || gallery.items || []).map((img: any) => (
        <img
          src={img.url || img.image}
          alt={img.alt || ''}
          loading="lazy"
          decoding="async"
          width="600"
          height="400"
          data-fallback={img.fallbackUrl || ''}
          onerror="this.onerror=null;this.src=this.dataset.fallback;"
        />
      ))}
    </div>
  </section>
)}
