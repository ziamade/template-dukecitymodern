---
// src/components/PhotoGallery.astro
// DCD Luxury gallery — 12-column masonry grid with hover overlays,
// 3D tilt on desktop, lightbox on click, staggered entrance
import galleryRaw from '../data/gallery.json';
const gallery = galleryRaw as any;
import OptimizedImg from './OptimizedImg.astro';

const images = gallery?.images || gallery?.items || [];
const hasGallery = images.length > 0;
---

{hasGallery && (
  <section class="gallery-section section" id="gallery">
    <div class="container">
      <h2 class="section-heading">Photos</h2>
    </div>

    <div class="gallery-grid stagger-parent container">
      {images.map((img: any, i: number) => (
        <button
          class={`gallery-item gallery-thumb ${i % 4 < 2 ? 'gallery-item--wide' : 'gallery-item--narrow'}`}
          data-tilt="3"
          data-index={i}
          type="button"
          aria-label={`View ${img.alt || `photo ${i + 1}`}`}
        >
          <OptimizedImg
            src={img.url || img.image}
            alt={img.alt || ''}
            width={800}
            height={600}
            fallback={img.fallbackUrl || img.fallback || ''}
            class="gallery-img"
          />
          <div class="gallery-overlay">
            <span class="gallery-caption">{img.alt || ''}</span>
            <svg class="gallery-zoom-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              <line x1="11" y1="8" x2="11" y2="14"/>
              <line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
        </button>
      ))}
    </div>

    <!-- Lightbox markup (driven by gallery-lightbox.js) -->
    <div class="gallery-lightbox" id="gallery-lightbox" aria-hidden="true" role="dialog" aria-label="Image lightbox">
      <button class="lightbox-close" aria-label="Close lightbox">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <div class="lightbox-img-wrap">
        <button class="lightbox-prev" aria-label="Previous image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <img class="lightbox-img" src="" alt="" />
        <button class="lightbox-next" aria-label="Next image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
      <p class="lightbox-caption"></p>
    </div>
  </section>
)}

<style>
  /* ── Gallery section ────────────────────────────────────────────── */
  .gallery-section {
    padding: var(--section-pad, 4rem) 0;
    overflow: hidden;
  }

  /* ── 12-column masonry grid ─────────────────────────────────────── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--gap, 1rem);
  }

  /* Alternating wide/narrow spans for visual rhythm */
  .gallery-item--wide {
    grid-column: span 7;
  }

  .gallery-item--narrow {
    grid-column: span 5;
  }

  /* Flip pattern for alternating rows */
  .gallery-item--wide:nth-child(4n+3) {
    grid-column: span 5;
  }

  .gallery-item--narrow:nth-child(4n+4) {
    grid-column: span 7;
  }

  /* ── Gallery item ───────────────────────────────────────────────── */
  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg, 20px);
    aspect-ratio: 3 / 2;
    cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--accent) 10%, var(--border));
    padding: 0;
    background: var(--surface);
    display: block;
    width: 100%;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .gallery-item :global(picture) {
    display: contents;
  }

  .gallery-item :global(.gallery-img),
  .gallery-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .gallery-item:hover :global(.gallery-img),
  .gallery-item:hover :global(img) {
    transform: scale(1.05);
  }

  /* ── Hover overlay ──────────────────────────────────────────────── */
  .gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 1.5rem;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .gallery-item:hover .gallery-overlay,
  .gallery-item:focus-visible .gallery-overlay {
    opacity: 1;
  }

  .gallery-caption {
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
    line-height: 1.4;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .gallery-zoom-icon {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 24px;
    height: 24px;
    color: rgba(255, 255, 255, 0.8);
  }

  .gallery-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Lightbox ───────────────────────────────────────────────────── */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .gallery-lightbox[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .lightbox-close:hover {
    color: #fff;
    transform: scale(1.1);
  }

  .lightbox-close svg {
    width: 28px;
    height: 28px;
  }

  .lightbox-img-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 90vw;
    max-height: 80vh;
  }

  .lightbox-img {
    max-width: 80vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: var(--radius, 12px);
  }

  .lightbox-prev,
  .lightbox-next {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    color: #fff;
    transform: scale(1.15);
  }

  .lightbox-prev svg,
  .lightbox-next svg {
    width: 32px;
    height: 32px;
  }

  .lightbox-caption {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    margin-top: 1rem;
    text-align: center;
  }

  /* ── Responsive ─────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .gallery-item--wide,
    .gallery-item--narrow,
    .gallery-item--wide:nth-child(4n+3),
    .gallery-item--narrow:nth-child(4n+4) {
      grid-column: span 1;
    }

    /* Disable tilt on mobile via removing the attribute */
    .gallery-item {
      border-radius: var(--radius, 12px);
    }

    .gallery-overlay {
      /* Always slightly visible on mobile for discoverability */
      opacity: 0.6;
    }

    .lightbox-prev,
    .lightbox-next {
      width: 36px;
      height: 36px;
    }

    .lightbox-prev svg,
    .lightbox-next svg {
      width: 24px;
      height: 24px;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .gallery-item--wide {
      grid-column: span 6;
    }

    .gallery-item--narrow {
      grid-column: span 6;
    }

    .gallery-item--wide:nth-child(4n+3) {
      grid-column: span 6;
    }

    .gallery-item--narrow:nth-child(4n+4) {
      grid-column: span 6;
    }
  }

  /* ── Reduced motion ─────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .gallery-item :global(.gallery-img),
    .gallery-item :global(img) {
      transition: none;
    }

    .gallery-overlay {
      transition: none;
    }

    .gallery-lightbox {
      transition: none;
    }
  }
</style>
