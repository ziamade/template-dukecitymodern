---
// src/components/ServiceCards.astro
const serviceFiles = import.meta.glob('../content/services/*.md', { eager: true });
const services = Object.values(serviceFiles)
  .map((mod: any) => mod.frontmatter)
  .sort((a: any, b: any) => (a.order || 0) - (b.order || 0));

const MAX_FEATURED = 3;
const featured = services.filter((s: any) => s.beforeImage).slice(0, MAX_FEATURED);
const secondary = services.slice(featured.length);
---
{services.length > 0 && (
  <section class="services-section section" id="services">
    <div class="container">
      <h2 class="section-heading">Our Services</h2>
      <div class="services-grid">
        {featured.map((svc: any) => (
          <a href="#contact" class="service-card">
            <img
              src={svc.beforeImage}
              alt={svc.title}
              loading="lazy"
              decoding="async"
              width="600"
              height="400"
              data-fallback={svc.fallbackImage || ''}
              onerror="this.onerror=null;this.src=this.dataset.fallback;"
            />
            <div class="service-card-body">
              <h3>{svc.title}</h3>
              <p>{svc.description}</p>
              {svc.startingPrice && (
                <span class="service-card-price">Starting at {svc.startingPrice}</span>
              )}
            </div>
          </a>
        ))}
      </div>
      {secondary.length > 0 && (
        <ul class="services-list">
          {secondary.map((svc: any) => (
            <li>
              <a href="#contact" class="services-list-item">
                <span class="services-list-name">{svc.title}</span>
                {svc.description && <span class="services-list-desc">{svc.description}</span>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
)}
