---
// src/components/Reviews.astro
import testimonials from '../data/testimonials.json';
import client from '../data/client.json';

interface Props { variant?: string | number; }

// Always use scroll variant — stacked/featured removed per feedback
const variant = 'scroll';

// Sort by rating desc so depth personalities that show only the first review get the best one
const items = [...(testimonials?.items || [])].sort((a: any, b: any) => (b.rating || 0) - (a.rating || 0));

// Real review count from Google, NOT items.length
const reviewCount = (testimonials as any)?.reviewCount
  || (testimonials as any)?.totalReviewCount
  || (testimonials as any)?.totalReviews
  || null;
const averageRating = (testimonials as any)?.averageRating || null;

// Build the "See all reviews" link
let allReviewsUrl = client.socials?.google || '';
const googleLinks = await import('../data/google-links.json').catch(() => null);
if (googleLinks?.default?.allReviews) allReviewsUrl = googleLinks.default.allReviews;

// Load source icons
const sourceIcons = import.meta.glob('/src/assets/svgs/icons/*.svg', { query: '?raw', import: 'default', eager: true });
function sourceIcon(name: string): string {
  return (sourceIcons[`/src/assets/svgs/icons/${name}.svg`] as string) || '';
}

// Build heading with real count
const headingParts: string[] = ['What Our Customers Say'];
if (averageRating && reviewCount) {
  headingParts[0] = `${averageRating} Stars from ${reviewCount}+ Reviews`;
} else if (reviewCount) {
  headingParts[0] = `${reviewCount}+ Customer Reviews`;
}
---
{items.length > 0 && (
  <section class="reviews-section section" id="reviews">
    <div class="container">
      <h2 class="section-heading">{headingParts[0]}</h2>

      <div class="reviews-scroll" style={`--review-count: ${items.length}`}>
        {items.map((t: any) => (
          <a
            class:list={["review-card", { "review-card--linked": t.url || allReviewsUrl }]}
            href={t.url || allReviewsUrl || undefined}
            target={t.url || allReviewsUrl ? "_blank" : undefined}
            rel={t.url || allReviewsUrl ? "noopener" : undefined}
          >
            <div class="review-stars">{Array.from({ length: t.rating }, () => '\u2605').join('')}</div>
            <details class="review-text-wrap">
              <summary class="review-text">{t.text}</summary>
              <p>{t.text}</p>
            </details>
            <div class="review-footer">
              <span class="review-avatar">{t.initials}</span>
              <span class="review-author">{t.author}</span>
              <span class="review-badge">
                <span class="review-badge-icon" set:html={sourceIcon(t.source?.toLowerCase() || 'star')} />
              </span>
            </div>
          </a>
        ))}
        {items.map((t: any) => (
          <a
            class:list={["review-card", { "review-card--linked": t.url || allReviewsUrl }]}
            href={t.url || allReviewsUrl || undefined}
            target={t.url || allReviewsUrl ? "_blank" : undefined}
            rel={t.url || allReviewsUrl ? "noopener" : undefined}
            aria-hidden="true"
          >
            <div class="review-stars">{Array.from({ length: t.rating }, () => '\u2605').join('')}</div>
            <details class="review-text-wrap">
              <summary class="review-text">{t.text}</summary>
              <p>{t.text}</p>
            </details>
            <div class="review-footer">
              <span class="review-avatar">{t.initials}</span>
              <span class="review-author">{t.author}</span>
              <span class="review-badge">
                <span class="review-badge-icon" set:html={sourceIcon(t.source?.toLowerCase() || 'star')} />
              </span>
            </div>
          </a>
        ))}
      </div>

      {allReviewsUrl && (
        <a href={allReviewsUrl} class="reviews-link" target="_blank" rel="noopener">
          See all {reviewCount ? `${reviewCount}+` : ''} reviews on Google &rarr;
        </a>
      )}
    </div>
  </section>
)}
