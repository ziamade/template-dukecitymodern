---
// src/components/Footer.astro
import client from '../data/client.json';
import location from '../data/location.json';
import contact from '../data/contact.json';
import { formatPhone } from '../lib/utils';
import googleLinks from '../data/google-links.json';
import { getGoogleLinkEntries } from '../lib/google-links';
import BrandName from './BrandName.astro';
import OptimizedImg from './OptimizedImg.astro';

const mapLinks = getGoogleLinkEntries(googleLinks);
const logoUrl = client.logoUrl || '';

const addressLine = location.address + ", " + location.city + " " + location.state + " " + location.zip;

const socialIcons = import.meta.glob('/src/assets/svgs/social/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true
});

function getSocialIcon(platform: string): string | null {
  const key = `/src/assets/svgs/social/${platform}.svg`;
  const fallback = `/src/assets/svgs/social/external-link.svg`;
  return (socialIcons[key] as string) || (socialIcons[fallback] as string) || null;
}
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div>
        <div class="footer-brand">
          {logoUrl && (
            <OptimizedImg
              src={logoUrl}
              alt={client.name}
              class="footer-logo-img"
              width={100}
              height={36}
            />
          )}
          <BrandName size="footer" />
        </div>
        <div class="footer-details">
          {location.address && <>{addressLine}<br /></>}
          {contact.phoneForTel && <a href={`tel:${contact.phoneForTel}`}>{formatPhone(contact.phoneForTel)}</a>}
        </div>
        {mapLinks.length > 0 && (
          <div class="footer-map-links">
            {mapLinks.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="footer-map-link">
                <span>{link.icon}</span> {link.label}
              </a>
            ))}
          </div>
        )}
      </div>
      <div class="footer-socials">
        {client.socials && Object.entries(client.socials).map(([platform, url]) => {
          if (!url) return null;
          const iconSvg = getSocialIcon(platform);
          const label = platform.charAt(0).toUpperCase() + platform.slice(1);
          return (
            <a href={url as string} target="_blank" rel="noopener" aria-label={label} class="social-icon">
              {iconSvg ? <Fragment set:html={iconSvg} /> : <span>{label}</span>}
            </a>
          );
        })}
      </div>
    </div>
    <div class="footer-copy">&copy; {new Date().getFullYear()} {client.name}. All rights reserved.</div>
    <div class="footer-powered">Powered by <a href="https://ziamade.com" target="_blank" rel="noopener">ZiaMade</a></div>
  </div>
</footer>

<style>
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .footer-logo-img {
    height: 36px;
    width: auto;
    max-width: 100px;
    object-fit: contain;
    border-radius: 4px;
  }

  .footer-socials {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--textMuted, #999);
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .social-icon:hover {
    color: var(--primary);
    opacity: 0.8;
  }

  .social-icon :global(svg) {
    width: 24px;
    height: 24px;
  }

  .footer-map-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .footer-map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--textMuted, #999);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border, rgba(255,255,255,0.1));
    border-radius: var(--cardRadius, 6px);
    transition: color 0.2s, border-color 0.2s;
  }

  .footer-map-link:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
</style>
