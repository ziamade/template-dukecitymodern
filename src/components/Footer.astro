---
// src/components/Footer.astro
// DCD Luxury footer — 3-column grid with brand, contact, service area
// Social icons with glow hover, divider glow line, ambient orb
import client from '../data/client.json';
import contact from '../data/contact.json';
import location from '../data/location.json';
import about from '../data/about.json';
import { formatPhone } from '../lib/utils';
import OptimizedImg from './OptimizedImg.astro';
import BrandName from './BrandName.astro';

let googleLinks: any = {};
try { googleLinks = (await import('../data/google-links.json')).default; } catch {}

const logoUrl = (client as any).logoUrl || '';
const phoneForTel = (contact as any).phoneForTel || '';
const email = (contact as any).email || '';
const address = (location as any).address || '';
const city = (location as any).city || '';
const state = (location as any).state || '';
const zip = (location as any).zip || '';

const tagline = (about as any)?.heading || (about as any)?.text?.slice(0, 120) || '';

// Parse service area cities from comma-separated string
const serviceAreaRaw = (client as any).serviceArea || '';
const serviceAreaCities = serviceAreaRaw
  .split(/,\s*(?:and\s+)?/)
  .map((c: string) => c.replace(/^and\s+/i, '').trim())
  .filter(Boolean);

// Social media platforms with SVG paths
const socialPlatforms: Record<string, { label: string; path: string; viewBox?: string }> = {
  facebook: {
    label: 'Facebook',
    path: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z',
  },
  instagram: {
    label: 'Instagram',
    path: 'M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2zm-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6zm9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6z',
  },
  google: {
    label: 'Google',
    path: 'M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z',
  },
  yelp: {
    label: 'Yelp',
    path: 'M20.16 12.73l-4.27 1.04a.46.46 0 00-.27.68l2.47 3.67c.24.35.76.2.8-.23l.34-4.81a.46.46 0 00-.37-.49l-.7.14zm-5.55 3.19l-1.64 4.06c-.14.35.18.7.55.6l4.53-1.26a.46.46 0 00.17-.78l-2.89-2.8a.46.46 0 00-.72.18zm-1.53-2.04l4.42-.35c.38-.03.53-.5.25-.76L14.5 9.88a.46.46 0 00-.73.15l-1.12 3.35a.46.46 0 00.43.5zm-1.84-1.08l1.94-3.95c.16-.34-.13-.72-.5-.65l-4.66.86a.46.46 0 00-.22.76l2.72 3.09a.46.46 0 00.72-.11zM10.1 7.63V2.67c0-.39-.47-.58-.74-.3L5.81 5.93c-.26.27-.1.7.27.7h3.56c.25 0 .46-.2.46-.46v1.46z',
  },
  youtube: {
    label: 'YouTube',
    path: 'M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19 31.67 31.67 0 000 12a31.67 31.67 0 00.5 5.81 3.02 3.02 0 002.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14A31.67 31.67 0 0024 12a31.67 31.67 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z',
  },
};

const socials = (client as any).socials || {};
const activeSocials = Object.entries(socials).filter(([, url]) => !!url);
---

<hr class="divider-glow" />

<footer class="site-footer" id="footer">
  <div class="glow-orb glow-orb--accent glow-orb--sm footer-orb" aria-hidden="true"></div>

  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand-col">
        <div class="footer-brand">
          {logoUrl && (
            <OptimizedImg
              src={logoUrl}
              alt={client.name}
              class="footer-logo-img"
              width={120}
              height={44}
            />
          )}
          <BrandName size="footer" />
        </div>
        {tagline && (
          <p class="footer-tagline">{tagline}</p>
        )}
      </div>

      <!-- Contact column -->
      <div class="footer-contact-col">
        <h4 class="footer-col-title">Contact</h4>
        <ul class="footer-contact-list">
          {phoneForTel && (
            <li>
              <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              <a href={`tel:${phoneForTel}`}>{formatPhone(phoneForTel)}</a>
            </li>
          )}
          {email && (
            <li>
              <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a href={`mailto:${email}`}>{email}</a>
            </li>
          )}
          {address && (
            <li>
              <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{address}{city ? `, ${city}` : ''}{state ? ` ${state}` : ''}{zip ? ` ${zip}` : ''}</span>
            </li>
          )}
        </ul>
      </div>

      <!-- Service Area column -->
      {serviceAreaCities.length > 0 && (
        <div class="footer-area-col">
          <h4 class="footer-col-title">Service Area</h4>
          <div class="footer-cities">
            {serviceAreaCities.map((cityName: string) => (
              <span class="footer-city">{cityName}</span>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Social icons -->
    {activeSocials.length > 0 && (
      <div class="footer-socials">
        {activeSocials.map(([platform, url]) => {
          const info = socialPlatforms[platform];
          if (!info) return null;
          return (
            <a href={url as string} target="_blank" rel="noopener" aria-label={info.label} class="social-btn">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={info.path} />
              </svg>
            </a>
          );
        })}
      </div>
    )}

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span class="footer-copyright">
        &copy; {new Date().getFullYear()} {client.name}. All rights reserved.
      </span>
      <a href="https://ziamade.com" target="_blank" rel="noopener" class="footer-ziamade">
        Site by ZiaMade
      </a>
    </div>
  </div>
</footer>

<style>
  /* ── Footer layout ──────────────────────────────────────────────── */
  .site-footer {
    background: var(--surface);
    color: var(--text);
    padding: 3rem 0 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .footer-orb {
    position: absolute;
    bottom: -100px;
    right: -80px;
    opacity: 0.12;
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-lg, 2rem);
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 2.5rem;
    }
  }

  /* ── Brand column ───────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .footer-logo-img {
    height: 40px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    border-radius: 4px;
  }

  .footer-tagline {
    font-size: 0.9375rem;
    color: var(--textMuted);
    line-height: 1.6;
    margin: 0;
    max-width: 32ch;
  }

  /* ── Column titles ──────────────────────────────────────────────── */
  .footer-col-title {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 1rem;
  }

  /* ── Contact list ───────────────────────────────────────────────── */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--textMuted);
  }

  .footer-contact-list a {
    color: var(--textMuted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact-list a:hover {
    color: var(--accent);
  }

  .footer-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--accent);
    opacity: 0.7;
    margin-top: 0.125rem;
  }

  /* ── Service area cities ────────────────────────────────────────── */
  .footer-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-city {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--textMuted);
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--borderSubtle, var(--border));
    border-radius: var(--radius, 12px);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .footer-city:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Social icons ───────────────────────────────────────────────── */
  .footer-socials {
    display: flex;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--borderSubtle, var(--border));
    margin-bottom: 1.5rem;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--borderSubtle, var(--border));
    color: var(--textMuted);
    background: transparent;
    text-decoration: none;
    transition:
      color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .social-btn svg {
    width: 18px;
    height: 18px;
  }

  .social-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  /* ── Bottom bar ─────────────────────────────────────────────────── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--borderSubtle, var(--border));
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: var(--textMuted);
    opacity: 0.6;
  }

  .footer-ziamade {
    font-size: 0.75rem;
    color: var(--textMuted);
    opacity: 0.4;
    text-decoration: none;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .footer-ziamade:hover {
    opacity: 1;
    color: var(--accent);
  }

  /* ── Responsive ─────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .site-footer {
      padding: 2rem 0 1.5rem;
      text-align: center;
    }

    .footer-brand {
      justify-content: center;
    }

    .footer-tagline {
      max-width: none;
    }

    .footer-contact-list li {
      justify-content: center;
    }

    .footer-cities {
      justify-content: center;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
