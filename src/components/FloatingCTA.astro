---
// src/components/FloatingCTA.astro
// Fixed-position CTA that appears when hero scrolls out of view
import contact from '../data/contact.json';

const phone = (contact as any)?.phoneForTel || (contact as any)?.phone || '';
const phoneClean = phone.replace(/\D/g, '');
const href = phoneClean ? `sms:+1${phoneClean}` : '#contact';
const label = phoneClean ? 'Text Us' : 'Get in Touch';
const ariaLabel = phoneClean ? `Text us at ${phone}` : 'Get in touch';
---
{(phoneClean || true) && (
  <a
    href={href}
    class="floating-cta btn--tactile"
    id="floating-cta"
    aria-label={ariaLabel}
  >
    <span class="floating-cta-icon" aria-hidden="true">
      {phoneClean ? (
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      ) : (
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      )}
    </span>
    <span class="floating-cta-text">{label}</span>
    <span class="floating-cta-ring" aria-hidden="true"></span>
  </a>
)}

<style>
  /* ===================================================================
     Floating CTA — fixed bottom-right
     =================================================================== */
  .floating-cta {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 900;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--accent);
    color: var(--bg, var(--background));
    border-radius: var(--radius-full, 9999px);
    font-family: var(--font-heading);
    font-size: var(--small-size, 0.875rem);
    font-weight: 600;
    text-decoration: none;
    letter-spacing: var(--tracking-wide, 0.08em);
    text-transform: uppercase;
    cursor: pointer;
    min-height: var(--touch-min, 44px);
    /* Tactile shadow from btn--tactile */
    box-shadow:
      0 6px 0 0 color-mix(in srgb, var(--accent) 70%, black),
      0 8px 20px rgba(0, 0, 0, 0.15);
    /* Hidden by default */
    opacity: 0;
    transform: translateY(20px) scale(0.9);
    pointer-events: none;
    transition:
      opacity 0.4s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      transform 0.4s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      box-shadow var(--duration-fast, 0.2s) ease;
  }

  .floating-cta.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .floating-cta:hover {
    transform: translateY(-3px) scale(1);
    box-shadow:
      0 8px 0 0 color-mix(in srgb, var(--accent) 70%, black),
      0 12px 28px rgba(0, 0, 0, 0.18);
    text-decoration: none;
  }

  .floating-cta:active {
    transform: translateY(3px) scale(0.98);
    box-shadow:
      0 2px 0 0 color-mix(in srgb, var(--accent) 70%, black),
      0 3px 8px rgba(0, 0, 0, 0.12);
  }

  .floating-cta:focus-visible {
    outline: 2px solid var(--bg, var(--background));
    outline-offset: 3px;
  }

  /* ── Icon ────────────────────────────────────────────────────── */
  .floating-cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .floating-cta-icon svg {
    stroke: var(--bg, var(--background));
  }

  /* ── Text (hidden on mobile) ────────────────────────────────── */
  .floating-cta-text {
    white-space: nowrap;
  }

  /* ── Pulse ring ─────────────────────────────────────────────── */
  .floating-cta-ring {
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    border: 2px solid var(--accent);
    opacity: 0;
    animation: cta-pulse-ring 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes cta-pulse-ring {
    0% {
      opacity: 0;
      transform: scale(1);
    }
    15% {
      opacity: 0.6;
    }
    40% {
      opacity: 0;
      transform: scale(1.15);
    }
    100% {
      opacity: 0;
      transform: scale(1.15);
    }
  }

  /* ── Mobile: icon-only circle ───────────────────────────────── */
  @media (max-width: 640px) {
    .floating-cta {
      padding: 0;
      width: 56px;
      height: 56px;
      justify-content: center;
      bottom: 1rem;
      right: 1rem;
    }

    .floating-cta-text {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  /* ── Account for mobile action bar ──────────────────────────── */
  @media (max-width: 767px) {
    .floating-cta {
      bottom: calc(72px + 1rem);
    }
  }

  /* ── Reduced motion ─────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .floating-cta {
      transition: none;
    }

    .floating-cta.visible {
      transform: none;
    }

    .floating-cta:hover {
      transform: none;
    }

    .floating-cta-ring {
      animation: none;
      display: none;
    }
  }
</style>

<script>
  // Show FloatingCTA when hero scrolls out of view
  document.addEventListener('DOMContentLoaded', () => {
    const cta = document.getElementById('floating-cta');
    const hero = document.getElementById('hero');
    if (!cta || !hero) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        // Show when hero is NOT intersecting (scrolled past)
        cta.classList.toggle('visible', !entry.isIntersecting);
      },
      {
        rootMargin: '0px',
        threshold: 0.1,
      }
    );

    observer.observe(hero);
  });
</script>
