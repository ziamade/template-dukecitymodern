---
// src/components/Hero.astro
// v4 rewrite: 4 hero styles (split, overlay, video, minimal)
// driven by theme.layout.heroStyle
import client from '../data/client.json';
import hero from '../data/hero.json';
import contact from '../data/contact.json';
import location from '../data/location.json';
import theme from '../data/theme.json';
import OptimizedImg from './OptimizedImg.astro';

const heroStyle = (theme as any).layout?.heroStyle || 'split';
const heroVideo = (hero as any)?.heroVideo || '';
const heroImage = (hero as any)?.heroImage || '';
const fallbackImage = (hero as any)?.fallbackImage || '';
const heroTagline = (hero as any)?.heroTagline || client.name;
const heroSubtitle = (hero as any)?.heroSubtitle || '';
const marqueeItems = (theme as any)?.marqueeItems || [];

// Hero stats from schema.json (authoritative source for rating/reviews)
let schema: any = {};
try { schema = (await import('../data/schema.json')).default; } catch {}
const aggregateRating = schema?.aggregateRating;
const ratingValue = aggregateRating?.ratingValue ? String(aggregateRating.ratingValue) : '';
const reviewCount = aggregateRating?.reviewCount ? String(aggregateRating.reviewCount) : '';
const foundingYear = parseInt((client as any).foundingYear || '0', 10);
const hasHeroStats = !!(ratingValue || reviewCount || (foundingYear > 1900));

// Location badge
const serviceArea = (client as any).serviceArea || '';
const city = (location as any)?.city || '';
const state = (location as any)?.state || '';
const badgeText = serviceArea || (city ? `Serving ${city}${state ? ` & ${state}` : ''}` : '');

// Contact for CTAs
const phone = (contact as any)?.phoneForTel || (contact as any)?.phone || '';
const phoneClean = phone.replace(/\D/g, '');

// Determine hero CTA targets
const primaryHref = phoneClean ? `sms:+1${phoneClean}` : '#contact';
const primaryText = phoneClean ? 'Text Us' : 'Get in Touch';
const secondaryHref = '#services';
const secondaryText = 'Our Services';
---
<section
  class:list={['hero', `hero--${heroStyle}`]}
  id="hero"
  data-hero-style={heroStyle}
>
  {/* Video background (video variant) */}
  {heroStyle === 'video' && heroVideo && (
    <div class="hero-video-wrap">
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        poster={heroImage || undefined}
      >
        <source
          src={heroVideo}
          type={heroVideo.endsWith('.webm') ? 'video/webm' : 'video/mp4'}
        />
      </video>
      <div class="hero-video-gradient"></div>
    </div>
  )}

  {/* Overlay background image (overlay variant) */}
  {heroStyle === 'overlay' && heroImage && (
    <div class="hero-backdrop">
      <OptimizedImg
        src={heroImage}
        alt=""
        width={1600}
        height={900}
        loading="eager"
        fetchpriority="high"
        fallback={fallbackImage}
      />
      <div class="hero-backdrop-gradient"></div>
    </div>
  )}

  <div class="container hero-container">
    <div class="hero-content">
      {/* Badge pill */}
      {badgeText && (
        <div class="hero-badge reveal-up">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          <span>{badgeText}</span>
        </div>
      )}

      {/* Tagline */}
      <h1 class="hero-tagline reveal-up">{heroTagline}</h1>

      {/* Subtitle */}
      {heroSubtitle && (
        <p class="hero-subtitle reveal-up">{heroSubtitle}</p>
      )}

      {/* Stats row */}
      {hasHeroStats && (
        <div class="hero-stats reveal-up">
          {ratingValue && (
            <span class="hero-stat">
              <span class="hero-stat-star" aria-hidden="true">★</span>
              <span class="hero-stat-value" data-count-to={ratingValue} data-count-delay="450">0</span>
            </span>
          )}
          {reviewCount && (
            <>
              {ratingValue && <span class="hero-stat-sep" aria-hidden="true">&middot;</span>}
              <span class="hero-stat">
                <span class="hero-stat-value" data-count-to={reviewCount} data-count-suffix="+" data-count-delay="450">0</span>
                <span class="hero-stat-label">Reviews</span>
              </span>
            </>
          )}
          {foundingYear > 1900 && (
            <>
              {(ratingValue || reviewCount) && <span class="hero-stat-sep" aria-hidden="true">&middot;</span>}
              <span class="hero-stat">
                <span class="hero-stat-label">Since</span>
                <span class="hero-stat-value">{foundingYear}</span>
              </span>
            </>
          )}
        </div>
      )}

      {/* CTA buttons */}
      <div class="hero-ctas reveal-up">
        <a href={primaryHref} class="btn btn--primary">{primaryText}</a>
        <a href={secondaryHref} class="btn btn--ghost">{secondaryText}</a>
      </div>

      {/* Open/closed badge + location */}
      <div class="hero-meta reveal-up">
        <div class="open-badge" id="open-badge">
          <span class="badge-text">Loading hours...</span>
        </div>
        {location?.city && (
          <a href={(location as any).mapLink || '#'} class="hero-location">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{(location as any).address ? `${(location as any).address}, ` : ''}{location.city}{(location as any).state ? `, ${(location as any).state}` : ''}{(location as any).zip ? ` ${(location as any).zip}` : ''}</span>
          </a>
        )}
      </div>
    </div>

    {/* Hero image (split variant only) */}
    {heroStyle === 'split' && heroImage && (
      <div class="hero-image reveal-scale">
        <OptimizedImg
          src={heroImage}
          alt={client.name}
          width={800}
          height={600}
          loading="eager"
          fetchpriority="high"
          fallback={fallbackImage}
        />
      </div>
    )}
  </div>

  {/* Marquee strip at bottom */}
  {marqueeItems.length > 0 && (
    <div class="hero-marquee-wrap">
      <div class="marquee-container">
        <div class="marquee">
          {[...marqueeItems, ...marqueeItems].map((item: string, i: number) => (
            <span class="marquee-item">
              {i > 0 && <span class="marquee-dot" aria-hidden="true">&bull;</span>}
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  )}
</section>

<style>
  /* ===================================================================
     Hero — Base
     =================================================================== */
  .hero {
    position: relative;
    color: var(--text);
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg, 2rem);
    flex: 1;
    padding-top: clamp(6rem, 4rem + 8vw, 10rem);
    padding-bottom: var(--gap-xl, 3rem);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--gap, 1rem);
    z-index: 2;
  }

  /* ── Badge pill ─────────────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    border-radius: var(--radius-full, 9999px);
    font-size: var(--caption-size, 0.75rem);
    font-weight: 600;
    color: var(--accent);
    letter-spacing: var(--tracking-wide, 0.08em);
    text-transform: uppercase;
    width: fit-content;
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-badge 2s ease-in-out infinite;
  }

  @keyframes pulse-badge {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  /* ── Tagline (h1) ───────────────────────────────────────────── */
  .hero-tagline {
    font-family: var(--font-heading);
    font-size: var(--hero-size, clamp(2.5rem, 1.5rem + 5vw, 5.5rem));
    font-weight: 700;
    line-height: var(--line-height-tight, 1.1);
    letter-spacing: var(--tracking-tight, -0.02em);
    color: var(--text);
    max-width: 18ch;
    position: relative;
  }

  /* Accent underline on tagline */
  .hero-tagline::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    margin-top: 0.75rem;
  }

  /* ── Subtitle ───────────────────────────────────────────────── */
  .hero-subtitle {
    font-size: var(--lead-size, clamp(1.125rem, 1rem + 0.5vw, 1.375rem));
    line-height: var(--line-height-body, 1.6);
    color: var(--textMuted, var(--text));
    max-width: 45ch;
  }

  /* ── Stats row ──────────────────────────────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
  }

  .hero-stat-star {
    color: var(--accent);
    font-size: 1.1em;
  }

  .hero-stat-value {
    font-family: var(--font-heading);
    color: var(--accent);
    font-size: 1rem;
    font-variant-numeric: tabular-nums;
  }

  .hero-stat-label {
    font-size: var(--small-size, 0.875rem);
    opacity: 0.7;
  }

  .hero-stat-sep {
    color: var(--textMuted, var(--text));
    opacity: 0.3;
    font-size: 1.25rem;
    line-height: 1;
  }

  /* ── CTAs ────────────────────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    gap: var(--gap, 1rem);
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  /* ── Meta (open badge + location) ───────────────────────────── */
  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .open-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full, 9999px);
    font-size: var(--small-size, 0.875rem);
    font-weight: 600;
    width: fit-content;
    background: color-mix(in srgb, var(--surface) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--border) 30%, transparent);
  }

  :global(.open-badge.open) {
    background: #16a34a;
    color: #fff;
    border: none;
  }

  :global(.open-badge.open)::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  :global(.open-badge.open-24-7) {
    background: rgba(22, 163, 74, 0.15);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.3);
    font-size: 1rem;
    padding: 0.5rem 1rem;
  }

  :global(.open-badge.open-24-7)::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  :global(.open-badge.closed) {
    background: color-mix(in srgb, var(--surface) 80%, transparent);
    color: var(--textMuted, var(--text));
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .hero-location {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--small-size, 0.875rem);
    opacity: 0.7;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--duration-fast, 0.2s) ease;
  }

  .hero-location:hover {
    opacity: 1;
    text-decoration: none;
  }

  /* ===================================================================
     Split variant — text left 60%, image right 40%
     =================================================================== */
  .hero--split .hero-container {
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg, var(--background)) 100%);
  }

  .hero--split .hero-image {
    position: relative;
    border-radius: var(--img-radius, var(--radius, 12px));
    overflow: hidden;
    box-shadow:
      8px 8px 0 color-mix(in srgb, var(--accent) 15%, var(--surface)),
      0 16px 40px rgba(0, 0, 0, 0.12);
  }

  .hero--split .hero-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  @media (min-width: 768px) {
    .hero--split .hero-container {
      flex-direction: row;
      align-items: center;
    }

    .hero--split .hero-content {
      flex: 3;
    }

    .hero--split .hero-image {
      flex: 2;
      max-height: 480px;
      box-shadow:
        12px 12px 0 color-mix(in srgb, var(--accent) 15%, var(--surface)),
        0 20px 50px rgba(0, 0, 0, 0.15);
    }
  }

  /* ===================================================================
     Overlay variant — full-bleed background, dark gradient, white text
     =================================================================== */
  .hero--overlay {
    background: #111;
  }

  .hero--overlay .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero--overlay .hero-backdrop :global(picture),
  .hero--overlay .hero-backdrop :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero--overlay .hero-backdrop-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.8) 30%,
      rgba(0, 0, 0, 0.4) 60%,
      rgba(0, 0, 0, 0.2)
    );
    z-index: 1;
  }

  .hero--overlay .hero-content {
    color: #f0eaec;
  }

  .hero--overlay .hero-tagline {
    color: #ffffff;
  }

  .hero--overlay .hero-subtitle {
    color: #e0e0e0;
  }

  .hero--overlay .hero-location {
    color: #d0d0d0;
  }

  .hero--overlay .hero-stat-value,
  .hero--overlay .hero-stat-star {
    color: #ffffff;
  }

  .hero--overlay .hero-stat-sep {
    color: rgba(255, 255, 255, 0.3);
  }

  .hero--overlay .hero-badge {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  .hero--overlay .open-badge {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  /* ===================================================================
     Video variant — video background, gradient to --bg
     =================================================================== */
  .hero--video {
    background: #111;
  }

  .hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .hero-video-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.3) 50%,
      var(--bg, var(--background)) 100%
    );
    z-index: 1;
  }

  .hero--video .hero-content {
    color: #f0eaec;
  }

  .hero--video .hero-tagline {
    color: #ffffff;
  }

  .hero--video .hero-subtitle {
    color: #e0e0e0;
  }

  .hero--video .hero-location {
    color: #d0d0d0;
  }

  .hero--video .hero-stat-value,
  .hero--video .hero-stat-star {
    color: #ffffff;
  }

  .hero--video .hero-stat-sep {
    color: rgba(255, 255, 255, 0.3);
  }

  .hero--video .hero-badge {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  .hero--video .open-badge {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  /* ===================================================================
     Minimal variant — text-focused, no image, large typography
     =================================================================== */
  .hero--minimal {
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg, var(--background)) 100%);
    text-align: center;
  }

  .hero--minimal .hero-container {
    align-items: center;
    justify-content: center;
  }

  .hero--minimal .hero-content {
    align-items: center;
    text-align: center;
  }

  .hero--minimal .hero-tagline {
    font-size: var(--mega-size, clamp(3.5rem, 2rem + 7vw, 9rem));
    max-width: 14ch;
    text-align: center;
  }

  .hero--minimal .hero-tagline::after {
    margin-left: auto;
    margin-right: auto;
  }

  .hero--minimal .hero-subtitle {
    max-width: 50ch;
    text-align: center;
  }

  .hero--minimal .hero-ctas {
    justify-content: center;
  }

  .hero--minimal .hero-meta {
    align-items: center;
  }

  .hero--minimal .hero-stats {
    justify-content: center;
  }

  /* ===================================================================
     Marquee strip at hero bottom
     =================================================================== */
  .hero-marquee-wrap {
    position: relative;
    z-index: 2;
    border-top: 1px solid color-mix(in srgb, var(--border) 20%, transparent);
    padding: 0.75rem 0;
    background: color-mix(in srgb, var(--surface) 40%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ===================================================================
     Responsive — mobile adjustments
     =================================================================== */
  @media (max-width: 640px) {
    .hero {
      min-height: 70vh;
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas .btn {
      width: 100%;
      justify-content: center;
    }

    .hero-tagline::after {
      width: 40px;
    }
  }

  /* ===================================================================
     Reduced motion
     =================================================================== */
  @media (prefers-reduced-motion: reduce) {
    .hero-badge-dot {
      animation: none;
    }

    .hero-video {
      animation: none;
    }
  }
</style>
