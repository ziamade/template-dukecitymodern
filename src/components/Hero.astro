---
// src/components/Hero.astro
import client from '../data/client.json';
import hero from '../data/hero.json';
import location from '../data/location.json';
import theme from '../data/theme.json';
import OptimizedImg from './OptimizedImg.astro';

interface Props {
  heroCta: { text: string; href: string };
  variant?: string | number;
}

const { heroCta, variant: variantProp } = Astro.props;
const variant = variantProp ?? theme.heroVariant ?? 1;
const heroVideo = (hero as any)?.heroVideo || '';
const isVideo = heroVideo && /\.(mp4|webm)$/i.test(heroVideo);
---
<section class="hero" data-variant={variant} id="hero">
  {variant === 2 && (
    isVideo ? (
      <video class="hero-video" autoplay muted loop playsinline poster={hero?.heroImage || ''}>
        <source src={heroVideo} type={heroVideo.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
      </video>
    ) : (
      <div class="hero-backdrop" style={hero?.heroImage ? `background-image: url('${hero.heroImage}')` : ''}></div>
    )
  )}
  {variant === 2 && <div class="hero-overlay"></div>}
  <div class="container hero-grid">
    <div class="hero-content">
      <h1 class="hero-tagline">{hero?.heroTagline || client.name}</h1>
      <p class="hero-subtitle">{hero?.heroSubtitle || ''}</p>
      <div class="open-badge" id="open-badge">
        <span class="badge-text">Loading hours...</span>
      </div>
      {location?.city && (
        <a href={location.mapLink || '#'} class="hero-location">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{location.city}{location.state ? `, ${location.state}` : ''}{location.zip ? ` ${location.zip}` : ''}</span>
        </a>
      )}
      <a href={heroCta.href || '#'} class="btn-primary">{heroCta.text || 'Learn More'}</a>
    </div>
    {variant !== 2 && (
      <div class="hero-photo">
        {hero?.heroImage && (
          <OptimizedImg
            src={hero.heroImage}
            alt={client.name}
            width={800}
            height={600}
            loading="eager"
            fetchpriority="high"
            fallback={hero.fallbackImage || ''}
          />
        )}
      </div>
    )}
  </div>
</section>
