---
// src/components/TrustStats.astro
// Trust bar stats variant — animated counters for key business metrics.
// Rendered when theme.json trust section variant is "stats".
import client from '../data/client.json';
import testimonials from '../data/testimonials.json';

const foundingYear = parseInt((client as any).foundingYear || '0', 10);
const hasFoundingYear = foundingYear > 1900;

const reviews = testimonials?.items || [];
const reviewCount = (testimonials as any)?.reviewCount
  || (testimonials as any)?.totalReviewCount
  || (testimonials as any)?.totalReviews
  || reviews.length;
const avgRating = (testimonials as any)?.averageRating
  ? String((testimonials as any).averageRating)
  : reviews.length > 0
    ? (reviews.reduce((sum: number, r: any) => sum + (r.rating || 0), 0) / reviews.length).toFixed(1)
    : '0';
const hasRating = parseFloat(avgRating) > 0;
const hasReviews = reviewCount > 0;

const license = (client as any).license || '';
const insured = (client as any).insured === true;
const hasLicense = !!(license || insured);

const hasStats = hasFoundingYear || hasRating || hasReviews;
---
{hasStats && (
  <section class="trust-section section" id="trust">
    <div class="container">
      <div class="trust-stats">
        {hasFoundingYear && (
          <div class="stat">
            <span class="stat-number">Est. {foundingYear}</span>
          </div>
        )}
        {hasRating && (
          <div class="stat">
            <span class="stat-number" data-count-to={avgRating}>0.0</span>
            <span class="stat-label">Stars</span>
          </div>
        )}
        {hasReviews && (
          <div class="stat">
            <span class="stat-number" data-count-to={String(reviewCount)} data-count-suffix="+">0</span>
            <span class="stat-label">Reviews</span>
          </div>
        )}
        {hasLicense && (
          <div class="stat">
            <span class="stat-number" style="font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);">
              {license || 'Licensed & Insured'}
            </span>
          </div>
        )}
      </div>
    </div>
  </section>
)}
