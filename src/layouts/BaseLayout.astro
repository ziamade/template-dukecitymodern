---
// src/layouts/BaseLayout.astro
import brand from '../data/brand.json';
import seo from '../data/seo.json';
import client from '../data/client.json';
import theme from '../data/theme.json';
import alert from '../data/alert.json';
import schema from '../data/schema.json';
import hours from '../data/hours.json';
import gallery from '../data/gallery.json';
import projects from '../data/projects.json';
import hero from '../data/hero.json';
import { generateThemeCSS, generateLayoutCSS } from '../lib/brand';
import { buildFontFaceCSS } from '../lib/fonts';
import { resolveImage } from '../lib/images';
import type { Brand, Theme } from '../lib/types';
import '../styles/base.css';
import '../styles/layout.css';
import '../styles/brand-name.css';
import '../styles/hero.css';
import '../styles/faq.css';
import '../styles/reviews.css';
import '../styles/gallery.css';
import '../styles/menu.css';
import '../styles/services.css';
import '../styles/form.css';
import '../styles/about.css';
import '../styles/footer.css';
import '../styles/accents.css';
import '../styles/tokens.css';
import '../styles/hours.css';
import '../styles/projects.css';
import '../styles/trust.css';
import '../styles/trust-stats.css';
import '../styles/bg-presets.css';
import '../styles/visual-depth.css';
import { ClientRouter } from "astro:transitions";

const typedBrand = brand as unknown as Brand;
const typedTheme = theme as unknown as Theme;
const themeCSS = generateThemeCSS(typedBrand);
const layout = (theme as any).layout || {};
const layoutCSS = generateLayoutCSS(layout);
const fontFaceCSS = buildFontFaceCSS(typedBrand);
const schemaJson = JSON.stringify(schema);
const hoursJson = JSON.stringify(hours);
const hasGallery = gallery?.images?.length > 0;
const hasProjects = (projects as any)?.projects?.length > 0;

// Preload hero image for LCP optimization
const heroImage = (hero as any)?.heroImage;
const heroResolved = heroImage ? resolveImage(heroImage) : null;

// Structural layout tokens → data attributes on body
const headerStyle = layout.headerStyle || 'glass';
const cardStyle = layout.cardStyle || 'shadow';
const sectionPattern = layout.sectionPattern || 'alternating';
const headerPosition = layout.headerPosition || 'hidden-on-scroll';
const motionIntensity = layout.motionIntensity || 'standard';
const atmosphereLevel = layout.atmosphereLevel || 'minimal';
const heroStyle = layout.heroStyle || 'split';
const dividerStyle = layout.dividerStyle || 'fade';
const buttonVariant = layout.buttonVariant || 'solid';
// Legacy tokens (kept for existing CSS until Phase 2 overhaul)
const bgPreset = layout.backgroundPreset || 'clean';
const depth = layout.depth || '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{seo.pageTitle || client.name}</title>
  <meta name="description" content={seo.metaDescription || ""}>
  <meta property="og:title" content={seo.ogTitle || client.name}>
  <meta property="og:description" content={seo.ogDescription || ""}>
  {seo.ogImage && <meta property="og:image" content={seo.ogImage} />}
  {seo.canonicalUrl && <link rel="canonical" href={seo.canonicalUrl} />}
  <ClientRouter fallback="swap" />
  {heroResolved && <link rel="preload" as="image" type="image/webp" href={heroResolved.src} fetchpriority="high" />}
  <link rel="icon" href="/assets/favicons/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/assets/favicons/favicon.ico" sizes="32x32">
  <link rel="icon" href="/assets/favicons/favicon-96x96.png" type="image/png" sizes="96x96">
  <style set:html={fontFaceCSS}></style>
  <style set:html={themeCSS}></style>
  {layoutCSS && <style set:html={layoutCSS}></style>}
</head>
<body
  data-accent={typedTheme.accentStyle || "border"}
  data-header-style={headerStyle}
  data-card-style={cardStyle}
  data-section-pattern={sectionPattern}
  data-header-position={headerPosition}
  data-motion={motionIntensity}
  data-atmosphere={atmosphereLevel}
  data-hero-style={heroStyle}
  data-divider={dividerStyle}
  data-btn-variant={buttonVariant}
  data-bg-preset={bgPreset}
  data-depth={depth || undefined}
>
  {alert && alert.enabled && alert.text && (
    <div class="alert-banner">{alert.text}</div>
  )}

  <slot />

  {schema && (
    <script type="application/ld+json" set:html={schemaJson}></script>
  )}
  <script type="application/json" id="hours-data" set:html={hoursJson}></script>
  <script is:inline src="/scripts/header-scroll.js"></script>
  <script is:inline src="/scripts/stagger.js"></script>
  <script is:inline src="/scripts/stat-counters.js"></script>
  <script is:inline src="/scripts/open-now.js"></script>
  <script is:inline src="/scripts/menu-scroll.js"></script>
  {hasGallery && (
    <>
      <script is:inline src="/scripts/gallery-hint.js"></script>
      <script is:inline src="/scripts/gallery-lightbox.js"></script>
    </>
  )}
  {hasProjects && (
    <script is:inline src="/scripts/gallery-slider.js"></script>
  )}
</body>
</html>
