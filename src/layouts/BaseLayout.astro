---
// src/layouts/BaseLayout.astro
import brand from '../data/brand.json';
import seo from '../data/seo.json';
import client from '../data/client.json';
import theme from '../data/theme.json';
import alert from '../data/alert.json';
import schema from '../data/schema.json';
import hours from '../data/hours.json';
import gallery from '../data/gallery.json';
import { generateThemeCSS, buildFontURL } from '../lib/brand';
import type { Brand, Theme } from '../lib/types';
import '../styles/base.css';
import '../styles/layout.css';
import '../styles/hero.css';
import '../styles/faq.css';
import '../styles/reviews.css';
import '../styles/gallery.css';
import '../styles/menu.css';
import '../styles/services.css';
import '../styles/form.css';
import '../styles/about.css';
import '../styles/footer.css';
import '../styles/accents.css';
import '../styles/theme-toggle.css';
import '../styles/hours.css';

const typedBrand = brand as unknown as Brand;
const typedTheme = theme as unknown as Theme;
const themeCSS = generateThemeCSS(typedBrand, typedTheme.defaultMode || 'light');
const fontURL = buildFontURL(typedBrand, client.name || '');
const schemaJson = JSON.stringify(schema);
const hoursJson = JSON.stringify(hours);
const hasGallery = gallery?.images?.length > 0;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{seo.pageTitle || client.name}</title>
  <meta name="description" content={seo.metaDescription || ""}>
  <meta property="og:title" content={seo.ogTitle || client.name}>
  <meta property="og:description" content={seo.ogDescription || ""}>
  {seo.ogImage && <meta property="og:image" content={seo.ogImage} />}
  {seo.canonicalUrl && <link rel="canonical" href={seo.canonicalUrl} />}
  <link rel="icon" href="/favicons/favicon.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href={fontURL} rel="stylesheet">
  <style set:html={themeCSS}></style>
</head>
<body data-accent={typedTheme.accentStyle || "border"}>
  <script is:inline>
    // Apply saved theme preference before paint (prevents flash)
    (function() {
      var saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>

  {alert && alert.enabled && alert.text && (
    <div class="alert-banner">{alert.text}</div>
  )}

  <slot />

  {schema && (
    <script type="application/ld+json" set:html={schemaJson}></script>
  )}
  <script type="application/json" id="hours-data" set:html={hoursJson}></script>
  <script is:inline src="/scripts/header-scroll.js"></script>
  <script is:inline src="/scripts/open-now.js"></script>
  <script is:inline src="/scripts/theme-toggle.js"></script>
  {hasGallery && (
    <script is:inline src="/scripts/gallery-hint.js"></script>
  )}
</body>
</html>
