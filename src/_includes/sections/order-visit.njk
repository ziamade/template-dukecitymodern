<section class="order-section section" id="order">
  <div class="container">
    <h2 class="section-heading">Order &amp; Visit</h2>
    {% if client.delivery %}
      <div class="delivery-buttons" style="margin-bottom:2rem;">
        {% if client.delivery.doordash %}<a href="{{ client.delivery.doordash }}" class="delivery-btn doordash" target="_blank" rel="noopener">DoorDash</a>{% endif %}
        {% if client.delivery.ubereats %}<a href="{{ client.delivery.ubereats }}" class="delivery-btn ubereats" target="_blank" rel="noopener">Uber Eats</a>{% endif %}
        {% if client.delivery.grubhub %}<a href="{{ client.delivery.grubhub }}" class="delivery-btn grubhub" target="_blank" rel="noopener">Grubhub</a>{% endif %}
      </div>
    {% endif %}
    <div class="order-details">
      {% if hours and hours.days %}
        <div class="hours-table">
          <h3>Hours</h3>
          <table>
            {% for d in hours.days %}
              <tr>
                <td>{{ d.day }}</td>
                <td>{% if d.open %}{{ d.open }} - {{ d.close }}{% else %}Closed{% endif %}</td>
              </tr>
            {% endfor %}
          </table>
        </div>
      {% endif %}
      <div class="contact-details">
        {% if contact.phoneForTel %}
          <p class="phone-large"><a href="tel:{{ contact.phoneForTel }}">{{ contact.phoneForTel }}</a></p>
        {% endif %}
        {% if location.address %}
          <p><a href="{{ location.mapLink }}">{{ location.address }}, {{ location.city }} {{ location.state }} {{ location.zip }}</a></p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
