<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div>
        <div class="footer-name">{{ client.name }}</div>
        <div class="footer-details">
          {% if location.address %}{{ location.address }}, {{ location.city }} {{ location.state }} {{ location.zip }}<br>{% endif %}
          {% if contact.phoneForTel %}<a href="tel:{{ contact.phoneForTel }}">{{ contact.phoneForTel }}</a>{% endif %}
        </div>
      </div>
      <div class="footer-socials">
        {% if client.socials.facebook %}<a href="{{ client.socials.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">FB</a>{% endif %}
        {% if client.socials.instagram %}<a href="{{ client.socials.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">IG</a>{% endif %}
        {% if client.socials.yelp %}<a href="{{ client.socials.yelp }}" target="_blank" rel="noopener" aria-label="Yelp">Yelp</a>{% endif %}
        {% if client.socials.google %}<a href="{{ client.socials.google }}" target="_blank" rel="noopener" aria-label="Google">G</a>{% endif %}
      </div>
    </div>
    <div class="footer-copy">&copy; 2026 {{ client.name }}. All rights reserved.</div>
  </div>
</footer>
