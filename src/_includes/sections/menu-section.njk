{% if menu and menu.categories and menu.categories.length > 0 %}
<section class="menu-section section" id="menu">
  <div class="container">
    <h2 class="section-heading">Our Menu</h2>
    {% if menu.categories.length > 1 %}
      <nav class="menu-cat-nav" aria-label="Menu categories">
        {% for cat in menu.categories %}
          <a href="#menu-{{ loop.index }}" class="menu-cat-link">{{ cat.name }}</a>
        {% endfor %}
      </nav>
    {% endif %}
    {% for cat in menu.categories %}
      <div class="menu-category" id="menu-{{ loop.index }}">
        <h3>{{ cat.name }}</h3>
        {% for item in cat.items %}
          <div class="menu-item">
            <div>
              <span class="menu-item-name">{{ item.name }}</span>
              {% if item.description %}<span class="menu-item-desc">{{ item.description }}</span>{% endif %}
            </div>
            {% if item.price %}<span class="menu-item-price">{{ item.price }}</span>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
    {% if client.delivery %}
      <div class="delivery-buttons">
        {% if client.delivery.doordash %}<a href="{{ client.delivery.doordash }}" class="delivery-btn doordash" target="_blank" rel="noopener">DoorDash</a>{% endif %}
        {% if client.delivery.ubereats %}<a href="{{ client.delivery.ubereats }}" class="delivery-btn ubereats" target="_blank" rel="noopener">Uber Eats</a>{% endif %}
        {% if client.delivery.grubhub %}<a href="{{ client.delivery.grubhub }}" class="delivery-btn grubhub" target="_blank" rel="noopener">Grubhub</a>{% endif %}
      </div>
    {% endif %}
  </div>
</section>
{% endif %}
