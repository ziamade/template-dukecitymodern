<!-- ============================================ -->
<!--              Order & Visit                   -->
<!-- ============================================ -->
<section class="order-cta" id="order">
    <div class="section-header">
        <h2 class="section-title">Order & Visit</h2>
        <p class="section-subtitle">Get your favorites delivered or dine with us</p>
    </div>

    {% if client.delivery %}
    <div class="delivery-buttons">
        {% if client.delivery.doordash %}
        <a href="{{ client.delivery.doordash }}" target="_blank" rel="noopener" class="delivery-btn delivery-btn--doordash" aria-label="Order from DoorDash (opens in new tab)">
            Order on DoorDash
        </a>
        {% endif %}
        {% if client.delivery.ubereats %}
        <a href="{{ client.delivery.ubereats }}" target="_blank" rel="noopener" class="delivery-btn delivery-btn--ubereats" aria-label="Order from Uber Eats (opens in new tab)">
            Order on Uber Eats
        </a>
        {% endif %}
        {% if client.delivery.grubhub %}
        <a href="{{ client.delivery.grubhub }}" target="_blank" rel="noopener" class="delivery-btn delivery-btn--grubhub" aria-label="Order from Grubhub (opens in new tab)">
            Order on Grubhub
        </a>
        {% endif %}
    </div>
    {% endif %}

    <div class="visit-info">
        <div class="visit-card">
            <h3>Call Us</h3>
            <a href="tel:{{ contact.phoneForTel }}">{{ contact.phoneForTel | formatPhone }}</a>
        </div>
        <div class="visit-card">
            <h3>Visit Us</h3>
            <p>{{ location.address }}</p>
            <p>{{ location.city }}, {{ location.state }} {{ location.zip }}</p>
            <a href="{{ location.mapLink }}" target="_blank" rel="noopener">Get Directions</a>
        </div>
        <div class="visit-card">
            <h3>Hours</h3>
            <ul class="visit-hours">
                {% for line in hours.hoursWeekdays | split(" | ") %}
                <li>{{ line }}</li>
                {% endfor %}
                {% if hours.hoursWeekend %}
                {% for line in hours.hoursWeekend | split(" | ") %}
                <li>{{ line }}</li>
                {% endfor %}
                {% endif %}
            </ul>
        </div>
    </div>
</section>
