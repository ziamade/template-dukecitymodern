<!-- ============================================ -->
<!--               Testimonials                   -->
<!-- ============================================ -->
<section class="testimonials" id="testimonials">
    <div class="testimonials-container">
        <div class="section-header">
            <div class="section-label">Client Reviews</div>
            <h2 class="section-title">What Our Customers Say</h2>
        </div>

        <div class="testimonial-carousel">
            <div class="testimonial-track" id="testimonialTrack">

                {% for t in testimonials.items %}
                <div class="testimonial-slide">
                    <a href="{{ t.url }}" target="_blank" rel="noopener noreferrer" class="testimonial-card">
                        <div class="testimonial-stars">
                            {% for i in range(0, t.rating) %}&#9733;{% endfor %}
                        </div>
                        <div class="testimonial-text">"{{ t.text }}"</div>
                        <div class="testimonial-author">
                            <div class="author-info">
                                <div class="author-avatar">{{ t.initials }}</div>
                                <div class="author-details">
                                    <h4>{{ t.author }}</h4>
                                    <p>{{ t.role }}</p>
                                </div>
                            </div>
                            <div class="review-source">
                                {% if t.source == "Google" %}
                                <svg width="16" height="16" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <path d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" fill="#FFC107"/>
                                    <path d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" fill="#FF3D00"/>
                                    <path d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" fill="#4CAF50"/>
                                    <path d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" fill="#1976D2"/>
                                </svg>
                                {% endif %}
                                <span>{{ t.source }}</span>
                            </div>
                        </div>
                    </a>
                </div>
                {% endfor %}

            </div>

            <div class="carousel-controls">
                <button class="carousel-btn" id="prevBtn" aria-label="Previous testimonial">&#8249;</button>
                <div class="carousel-indicators" id="indicators"></div>
                <button class="carousel-btn" id="nextBtn" aria-label="Next testimonial">&#8250;</button>
            </div>
        </div>
    </div>
</section>
