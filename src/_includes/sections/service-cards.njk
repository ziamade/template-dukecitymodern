{% set services = collections.service %}
{% if services and services.length > 0 %}
<section class="services-section section" id="services">
  <div class="container">
    <h2 class="section-heading">Our Services</h2>
    <div class="services-grid">
      {% for svc in services %}
        <a href="#quote-form" class="service-card">
          {% if svc.data.beforeImage %}
            <img src="{{ svc.data.beforeImage }}" alt="{{ svc.data.title }}" loading="lazy"
                 {% if svc.data.fallbackImage %}data-fallback="{{ svc.data.fallbackImage }}" onerror="this.onerror=null;this.src=this.dataset.fallback;"{% endif %}>
          {% endif %}
          <div class="service-card-body">
            <h3>{{ svc.data.title }}</h3>
            <p>{{ svc.data.description }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
