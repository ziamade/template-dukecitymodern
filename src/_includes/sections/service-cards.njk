<!-- ============================================ -->
<!--                Service Cards                  -->
<!-- ============================================ -->
<section class="services" id="services">
    <div class="section-header">
        <div class="section-label">{{ sectionLabel }}</div>
        <h2 class="section-title">{{ sectionTitle }}</h2>
    </div>
    <div class="services-grid">
        {% for service in collections.service | sort(false, false, 'data.order') %}
        {% if service.data.beforeImage and (service.data.beforeImage | isRemoteUrl) %}
            {% set beforeUrl = service.data.beforeImage %}
        {% else %}
            {% set beforeUrl %}{% getUrl service.data.beforeImage %}{% endset %}
        {% endif %}
        {% if service.data.afterImage %}
            {% if service.data.afterImage | isRemoteUrl %}
                {% set afterUrl = service.data.afterImage %}
            {% else %}
                {% set afterUrl %}{% getUrl service.data.afterImage %}{% endset %}
            {% endif %}
        {% endif %}
        <div class="service-card">
            <img
                src="{{ beforeUrl | safe }}"
                {% if service.data.afterImage %}
                data-before="{{ beforeUrl | safe }}"
                data-after="{{ afterUrl | safe }}"
                {% endif %}
                {% if service.data.fallbackImage %}
                data-fallback="{{ service.data.fallbackImage }}"
                onerror="this.onerror=null;this.src=this.dataset.fallback;"
                {% endif %}
                alt="{{ service.data.title }}"
                class="service-image"
                loading="lazy">
            <div class="service-content">
                <h3>{{ service.data.title }}</h3>
                <p>{{ service.data.description }}</p>
            </div>
        </div>
        {% endfor %}
    </div>
</section>
